# OpenRouter API Key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Text model (for text-based prompt generation)
# Recommended free: qwen/qwen3-6b:free  (Qwen3, 131K context, thinking mode)
# Other free: google/gemma-3-27b-it:free, mistralai/mistral-7b-instruct:free
# Paid: openai/gpt-4o, anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free

# Vision model (for image analysis — must support image input)
# NOTE: Qwen3 is TEXT-ONLY, so keep a vision-capable model here
# Recommended: google/gemini-flash-1.5, openai/gpt-4o, anthropic/claude-3.5-sonnet
OPENROUTER_VISION_MODEL=bytedance-seed/seed-2.0-mini

# Output directory for saved prompts
OUTPUT_DIR=outputs

# Project images folder (place reference images here)
IMAGES_DIR=images
